# SimpleMappr Docker Environment Configuration
# Copy this file to .env and fill in the values

# =============================================================================
# ENVIRONMENT
# =============================================================================
# Options: development, production, testing
ENVIRONMENT=development

# =============================================================================
# APPLICATION
# =============================================================================
# Public URL of the application (no trailing slash)
APP_URL=http://localhost:8080

# Port to expose the app on (default 8080)
APP_PORT=8080

# Secret key for session encryption (generate a random 32+ character string)
# In production, use: openssl rand -hex 32
APP_SECRET=change-me-in-production-use-random-string

# =============================================================================
# OAUTH: ORCID
# =============================================================================
# Register your app at https://orcid.org/developer-tools
# Redirect URI should be: {APP_URL}/callback/orcid
ORCID_CLIENT_ID=APP-XXXXXXXXXXXXXXXX
ORCID_CLIENT_SECRET=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# =============================================================================
# OAUTH: GOOGLE
# =============================================================================
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: {APP_URL}/callback/google
GOOGLE_CLIENT_ID=xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxxx

# =============================================================================
# RENDER SERVICE
# =============================================================================
# URL of the render microservice (internal Docker network)
# In Docker, this is handled automatically via docker-compose
RENDER_SERVICE_URL=http://render:8080

# =============================================================================
# DATABASE
# =============================================================================
# Path to SQLite database (inside Docker container)
# The volume mount handles persistence
DATABASE_PATH=/var/lib/simplemappr/simplemappr.db
