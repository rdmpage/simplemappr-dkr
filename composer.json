{
    "name": "simplemappr/simplemappr",
    "description": "A point map web application for quality publications and presentations",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "David P. Shorthouse",
            "email": "davidpshorthouse@gmail.com"
        }
    ],
    "homepage": "https://www.simplemappr.net",
    "require": {
        "php": ">=7.4",
        "ext-pdo": "*",
        "ext-pdo_sqlite": "*",
        "ext-curl": "*",
        "ext-json": "*",
        "ext-gd": "*",
        "league/oauth2-client": "^2.7",
        "league/oauth2-google": "^4.0",
        "league/csv": "^9.0",
        "phayes/geophp": "^1.2",
        "twig/twig": "^3.0",
        "symfony/yaml": "^5.0 || ^6.0",
        "neitanod/forceutf8": "^2.0",
        "phpoffice/phpword": "^1.0",
        "phpoffice/phppresentation": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0",
        "squizlabs/php_codesniffer": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "SimpleMappr\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SimpleMappr\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "cs": "phpcs --standard=PSR12 src/",
        "cs-fix": "phpcbf --standard=PSR12 src/"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
